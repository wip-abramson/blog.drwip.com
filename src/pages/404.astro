---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="That page could not be found.">
  <div class="mx-auto max-w-[680px] px-6 py-32 text-center">
    <p class="font-mono text-sm uppercase tracking-widest text-brand-muted">404</p>
    <h1 class="mt-3 font-heading text-3xl text-brand-text sm:text-4xl">
      This page wandered off.
    </h1>
    <p class="mt-4 text-brand-muted">
      The note you were looking for isn't here.
    </p>
    <div class="mt-8 flex justify-center gap-6 text-sm">
      <a
        href="/"
        class="text-brand-accent underline underline-offset-4 hover:decoration-2"
      >
        Home
      </a>
      <a
        href="/posts"
        class="text-brand-accent underline underline-offset-4 hover:decoration-2"
      >
        All posts
      </a>
    </div>
  </div>
</BaseLayout>
