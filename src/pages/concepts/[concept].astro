---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import ReflectionItem from "../../components/ReflectionItem.astro";
import LibraryListItem from "../../components/LibraryListItem.astro";
import { getAllConcepts, conceptTitle, type Concept } from "../../lib/concepts";

/** One page per concept. */
export async function getStaticPaths() {
  const concepts = await getAllConcepts();
  return concepts.map((concept) => ({
    params: { concept: concept.slug },
    props: { concept },
  }));
}

interface Props {
  concept: Concept;
}

const { concept } = Astro.props;
const { posts, reflections, books } = concept;

// The concept page is the concept's home, so it gets a proper capitalised
// name ("Identity") — the "#identity" hashtag form is only for wayfinding.
const displayName = conceptTitle(concept.name);

const phrase = [
  posts.length && `${posts.length} ${posts.length === 1 ? "note" : "notes"}`,
  reflections.length &&
    `${reflections.length} ${reflections.length === 1 ? "reflection" : "reflections"}`,
  books.length && `${books.length} ${books.length === 1 ? "book" : "books"}`,
]
  .filter(Boolean)
  .join(" · ");
---

<BaseLayout
  title={displayName}
  description={`Notes and books by Dr Wip on ${concept.name}.`}
>
  <div class="mx-auto max-w-[720px] px-6">
    <header class="pb-8 pt-20 sm:pt-24">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-brand-muted">
        Concept
      </p>
      <h1 class="font-heading text-3xl text-brand-text sm:text-4xl">
        {displayName}
      </h1>
      <p class="mt-3 text-brand-muted">
        {phrase} growing from this concept.
      </p>
    </header>

    <div class="border-t border-brand-border pt-8">
      {
        posts.length > 0 && (
          <div class="divide-y divide-brand-border">
            {posts.map((post) => (
              <PostListItem post={post} />
            ))}
          </div>
        )
      }

      {
        reflections.length > 0 && (
          <section
            class:list={[
              posts.length > 0 && "mt-10 border-t border-brand-border pt-8",
            ]}
          >
            <h2 class="mb-2 font-mono text-xs uppercase tracking-widest text-brand-muted">
              Thinking about
            </h2>
            <div class="divide-y divide-brand-border">
              {reflections.map((reflection) => (
                <ReflectionItem reflection={reflection} />
              ))}
            </div>
          </section>
        )
      }

      {
        books.length > 0 && (
          <section
            class:list={[
              (posts.length > 0 || reflections.length > 0) &&
                "mt-10 border-t border-brand-border pt-8",
            ]}
          >
            <h2 class="mb-2 font-mono text-xs uppercase tracking-widest text-brand-muted">
              From the library
            </h2>
            <div class="divide-y divide-brand-border">
              {books.map((entry) => (
                <LibraryListItem entry={entry} />
              ))}
            </div>
          </section>
        )
      }
    </div>

    <p class="mt-8">
      <a
        href="/concepts"
        class="text-sm text-brand-muted transition-colors hover:text-brand-accent"
      >
        ← All concepts
      </a>
    </p>
  </div>
</BaseLayout>
