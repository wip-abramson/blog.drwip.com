---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import { getAllConcepts, conceptTitle, type Concept } from "../../lib/concepts";

/** One page per concept. */
export async function getStaticPaths() {
  const concepts = await getAllConcepts();
  return concepts.map((concept) => ({
    params: { concept: concept.slug },
    props: { concept },
  }));
}

interface Props {
  concept: Concept;
}

const { concept } = Astro.props;
const count = concept.count;

// The concept page is the concept's home, so it gets a proper capitalised
// name ("Identity") — the "#identity" hashtag form is only for wayfinding.
const displayName = conceptTitle(concept.name);
---

<BaseLayout
  title={displayName}
  description={`Notes by Dr Wip on ${concept.name}.`}
>
  <div class="mx-auto max-w-[720px] px-6">
    <header class="pb-8 pt-20 sm:pt-24">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-brand-muted">
        Concept
      </p>
      <h1 class="font-heading text-3xl text-brand-text sm:text-4xl">
        {displayName}
      </h1>
      <p class="mt-3 text-brand-muted">
        {count} {count === 1 ? "note" : "notes"} growing from this concept.
      </p>
    </header>

    <div class="divide-y divide-brand-border border-t border-brand-border pt-8">
      {concept.posts.map((post) => <PostListItem post={post} />)}
    </div>

    <p class="mt-8">
      <a
        href="/concepts"
        class="text-sm text-brand-muted transition-colors hover:text-brand-accent"
      >
        ← All concepts
      </a>
    </p>
  </div>
</BaseLayout>
