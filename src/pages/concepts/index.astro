---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllConcepts } from "../../lib/concepts";

const concepts = await getAllConcepts();
---

<BaseLayout
  title="Concepts"
  description="Browse Dr Wip's notes by concept — a growing map of related ideas."
>
  <div class="mx-auto max-w-[720px] px-6">
    <header class="pb-8 pt-20 sm:pt-24">
      <h1 class="font-heading text-3xl text-brand-text sm:text-4xl">Concepts</h1>
      <p class="mt-3 max-w-[34rem] leading-relaxed text-brand-muted">
        Notes gathered by the ideas they return to — a map that thickens as the
        garden grows. Follow a thread to see everything growing from it.
      </p>
    </header>

    {
      concepts.length > 0 ? (
        <ul class="flex flex-wrap gap-2 border-t border-brand-border pt-8">
          {concepts.map((concept) => (
            <li>
              <a
                href={`/concepts/${concept.slug}/`}
                class="group inline-flex items-baseline gap-2 rounded-lg border border-brand-border bg-brand-surface px-3 py-1.5 transition-colors hover:border-brand-accent"
              >
                <span class="font-mono text-sm text-brand-text transition-colors group-hover:text-brand-accent">
                  #{concept.name}
                </span>
                <span class="font-mono text-xs text-brand-muted">
                  {concept.count}
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="border-t border-brand-border py-12 leading-relaxed text-brand-muted">
          No concepts yet — they'll appear here as tagged posts are published.
        </p>
      )
    }
  </div>
</BaseLayout>
