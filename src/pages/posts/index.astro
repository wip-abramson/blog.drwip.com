---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import { getPublishedPosts } from "../../lib/posts";
import { LINKS } from "../../consts";

const posts = await getPublishedPosts();
const count = posts.length;
---

<BaseLayout
  title="Writing"
  description="All writing and research notes by Dr Wip, newest first."
>
  <div class="mx-auto max-w-[720px] px-6">
    <header class="pb-8 pt-20 sm:pt-24">
      <h1 class="font-heading text-3xl text-brand-text sm:text-4xl">Writing</h1>
      <p class="mt-3 text-brand-muted">
        {
          count > 0
            ? `${count} ${count === 1 ? "note" : "notes"}, newest first.`
            : "Notes and longer pieces, newest first."
        }
      </p>
    </header>

    {
      count > 0 ? (
        <div class="divide-y divide-brand-border border-t border-brand-border pt-8">
          {posts.map((post) => (
            <PostListItem post={post} />
          ))}
        </div>
      ) : (
        <div class="border-t border-brand-border py-12">
          <p class="leading-relaxed text-brand-muted">
            Nothing has sprouted here yet. The first notes are being written — {" "}
            <a
              href={LINKS.subscribe}
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-accent underline underline-offset-4 hover:decoration-2"
            >
              subscribe on Words from Wip
            </a>{" "}
            to catch them as they land.
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
