---
import { NAV_LINKS, LINKS } from "../consts";

// Mark the current section as active (handles nested routes like /posts/x).
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="sticky top-0 z-50 border-b border-brand-border bg-brand-bg/95 backdrop-blur">
  <nav
    class="mx-auto flex h-14 max-w-[720px] items-center justify-between px-6"
    aria-label="Primary"
  >
    <a
      href="/"
      class="font-mono text-sm text-brand-text transition-colors hover:text-brand-accent"
    >
      Will Abramson
    </a>

    <!-- Desktop navigation ------------------------------------------- -->
    <div class="hidden items-center gap-6 sm:flex">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "text-sm transition-colors hover:text-brand-accent",
              isActive(link.href) ? "text-brand-accent" : "text-brand-muted",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={LINKS.subscribe}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm text-brand-muted transition-colors hover:text-brand-accent"
      >
        Subscribe
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path
            d="M1 9L9 1M9 1H3M9 1V7"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <!-- Mobile menu toggle ------------------------------------------- -->
    <button
      type="button"
      id="nav-toggle"
      class="-mr-2 inline-flex items-center justify-center p-2 text-brand-text sm:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <svg
        data-icon="open"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 6h14M3 10h14M3 14h14"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
      <svg
        data-icon="close"
        class="hidden"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M5 5l10 10M15 5L5 15"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile navigation -------------------------------------------- -->
  <div id="nav-menu" class="hidden border-t border-brand-border sm:hidden">
    <div class="mx-auto flex max-w-[720px] flex-col px-6 py-2">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "py-2.5 text-sm transition-colors hover:text-brand-accent",
              isActive(link.href) ? "text-brand-accent" : "text-brand-muted",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={LINKS.subscribe}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 py-2.5 text-sm text-brand-muted transition-colors hover:text-brand-accent"
      >
        Subscribe
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path
            d="M1 9L9 1M9 1H3M9 1V7"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  if (toggle && menu) {
    const openIcon = toggle.querySelector("[data-icon='open']");
    const closeIcon = toggle.querySelector("[data-icon='close']");

    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      toggle.setAttribute("aria-expanded", String(open));
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
    };

    toggle.addEventListener("click", (event) => {
      event.stopPropagation();
      setOpen(menu.classList.contains("hidden"));
    });

    // Tapping elsewhere or pressing Escape closes the menu.
    document.addEventListener("click", () => setOpen(false));
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });
  }
</script>
