---
import type { Post } from "../lib/posts";
import FormattedDate from "./FormattedDate.astro";
import ConceptTags from "./ConceptTags.astro";

/**
 * One entry in a list of posts. Used on the homepage and the posts index.
 */
interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, date, tags, draft } = post.data;
const href = `/posts/${post.id}/`;
---

<article class="group py-7 first:pt-0">
  <a href={href} class="block">
    <div class="mb-2 flex items-center gap-3 font-mono text-xs text-brand-muted">
      <FormattedDate date={date} />
      {
        draft && (
          <span class="rounded border border-amber-200 bg-amber-50 px-1.5 py-0.5 text-amber-700">
            Draft
          </span>
        )
      }
    </div>

    <h3
      class="font-heading text-xl leading-snug text-brand-text transition-colors group-hover:text-brand-accent"
    >
      {title}
    </h3>

    <p class="mt-1.5 leading-relaxed text-brand-muted">{description}</p>
  </a>

  <ConceptTags tags={tags} class="mt-3" />
</article>
