---
import { Image } from "astro:assets";
import { formatReadDate, type LibraryEntry } from "../lib/library";
import ConceptTags from "./ConceptTags.astro";

/**
 * One entry in the library shelf — a small framed thumbnail of the
 * annotation page beside the book's details. Used on /library and on
 * concept pages.
 */
interface Props {
  entry: LibraryEntry;
}

const { entry } = Astro.props;
const { title, author, read, influence, summary, tags, annotations } = entry.data;
const href = `/library/${entry.id}/`;
const blurb = influence ?? summary;
const cover = annotations[0];
---

<article class="group py-7 first:pt-0">
  <a href={href} class="flex gap-5">
    {
      cover && (
        <Image
          src={cover.image}
          alt={`Handwritten annotation page for ${title}`}
          width={280}
          class="hidden h-24 w-32 shrink-0 rounded border border-brand-border object-cover sm:block"
        />
      )
    }
    <div class="min-w-0">
      <h3
        class="font-heading text-xl leading-snug text-brand-text transition-colors group-hover:text-brand-accent"
      >
        {title}
      </h3>
      <p class="mt-0.5 font-mono text-xs text-brand-muted">
        {author}{read && ` · ${formatReadDate(read)}`}
      </p>
      {blurb && <p class="mt-2 leading-relaxed text-brand-muted">{blurb}</p>}
    </div>
  </a>

  <ConceptTags tags={tags} class="mt-3" />
</article>
